<!-- Free Audit Modal -->
<link rel="stylesheet" href="./Numerique_files/audit-modal.css">
<div id="auditModal" class="audit-modal">
    <div class="audit-modal-content">
        <div class="audit-modal-header">
            <span class="audit-modal-close">&times;</span>
            <h2>Get Your Free Audit</h2>
            <p>Let us help you grow your business with our expert analysis</p>
        </div>
        <div class="audit-modal-body">
            <div class="audit-success-message">
                Thank you! We'll get back to you soon.
            </div>
            <form id="auditForm">
                <div class="audit-form-group">
                    <label for="auditName">Full Name *</label>
                    <input type="text" id="auditName" name="name" required placeholder="Enter your full name">
                </div>
                <div class="audit-form-group">
                    <label for="auditEmail">Email Address *</label>
                    <input type="email" id="auditEmail" name="email" required placeholder="your.email@example.com">
                </div>
                <div class="audit-form-group">
                    <label for="auditPhone">Phone Number *</label>
                    <input type="tel" id="auditPhone" name="phone" required placeholder="+1 (555) 000-0000">
                </div>
                <div class="audit-form-group">
                    <label for="auditCompany">Company Name</label>
                    <input type="text" id="auditCompany" name="company" placeholder="Your company name">
                </div>
                <div class="audit-form-group">
                    <label for="auditWebsite">Website URL</label>
                    <input type="url" id="auditWebsite" name="website" placeholder="https://www.yourwebsite.com">
                </div>
                <div class="audit-form-group">
                    <label for="auditService">Service Interest *</label>
                    <select id="auditService" name="service" required>
                        <option value="">Select a service</option>
                        <option value="seo">SEO Services</option>
                        <option value="ppc">PPC Management</option>
                        <option value="social-media">Social Media Marketing</option>
                        <option value="content">Content Marketing</option>
                        <option value="web-design">Web Design</option>
                        <option value="email">Email Marketing</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="audit-form-group">
                    <label for="auditMessage">Additional Information</label>
                    <textarea id="auditMessage" name="message" placeholder="Tell us more about your business and goals..."></textarea>
                </div>
                <button type="submit" class="audit-submit-btn">Request Free Audit</button>
            </form>
        </div>
    </div>
</div>
<script src="./Numerique_files/audit-modal.js"></script>

</body></html>