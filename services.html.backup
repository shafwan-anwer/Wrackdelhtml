			<script>
				// Force first tab content to be visible on page load
				document.addEventListener('DOMContentLoaded', function() {
					// Find all active tab content elements
					var activeTabs = document.querySelectorAll('.elementor-tab-content.elementor-active');
					activeTabs.forEach(function(tab) {
						tab.style.display = 'block';
						tab.style.visibility = 'visible';
						tab.removeAttribute('hidden');
					});
				});

				// Also run immediately in case DOMContentLoaded already fired
				if (document.readyState === 'loading') {
					// Do nothing, wait for DOMContentLoaded
				} else {
					// DOM is already ready
					var activeTabs = document.querySelectorAll('.elementor-tab-content.elementor-active');
					activeTabs.forEach(function(tab) {
						tab.style.display = 'block';
						tab.style.visibility = 'visible';
						tab.removeAttribute('hidden');
					});
				}
