<span id="elementor-device-mode" class="elementor-screen-only"></span><svg style="display: none;" class="e-font-icon-svg-symbols"></svg><script>
// Force active tab content to be visible - runs AFTER all other scripts
(function() {
    function showActiveTabs() {
        var activeTabs = document.querySelectorAll('.elementor-tab-content.elementor-active');
        activeTabs.forEach(function(tab) {
            tab.style.display = 'block';
            tab.style.visibility = 'visible';
            tab.style.opacity = '1';
            tab.removeAttribute('hidden');
        });
    }

    // Run immediately
    showActiveTabs();

    // Run after a slight delay to ensure it overrides any other scripts
    setTimeout(showActiveTabs, 100);
    setTimeout(showActiveTabs, 500);
    setTimeout(showActiveTabs, 1000);
})();
</script>
<script src="./Numerique_files/tab-fix.js"></script>
